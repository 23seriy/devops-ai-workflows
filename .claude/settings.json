{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(./scripts/validate-repo.sh)",
      "Bash(./scripts/validate-repo.sh:*)",
      "Bash(./scripts/k8s-snapshot.sh:*)",
      "Bash(./scripts/aws-whoami.sh:*)",
      "Bash(./scripts/stale-branches.sh:*)",
      "Bash(find .:*)",
      "Bash(find scripts:*)",
      "Bash(find .claude:*)",
      "Bash(find prompts:*)",
      "Bash(find rules:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(ls:*)",
      "Bash(wc:*)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git for-each-ref:*)",
      "Bash(markdownlint:*)",
      "Bash(markdownlint-cli2:*)",
      "Bash(shellcheck:*)",
      "Bash(yamllint:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Bash(kubectl apply:*)",
      "Bash(kubectl delete:*)",
      "Bash(kubectl scale:*)",
      "Bash(kubectl drain:*)",
      "Bash(kubectl cordon:*)",
      "Bash(kubectl taint:*)",
      "Bash(helm install:*)",
      "Bash(helm upgrade:*)",
      "Bash(helm uninstall:*)",
      "Bash(helm rollback:*)",
      "Bash(terraform apply:*)",
      "Bash(terraform destroy:*)",
      "Bash(terraform state rm:*)",
      "Bash(terraform state mv:*)",
      "Bash(terraform force-unlock:*)",
      "Bash(aws iam delete:*)",
      "Bash(aws iam create:*)",
      "Bash(aws iam put:*)",
      "Bash(aws s3 rm:*)",
      "Bash(aws ec2 terminate-instances:*)",
      "Bash(aws rds delete:*)"
    ]
  }
}
